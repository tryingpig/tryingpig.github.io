---
import type { Project } from '../lib/posts';
interface Props { project: Project }
const { project: p } = Astro.props;
---

<a class="card" href={p.url} target="_blank" rel="noopener">
  <div class="emoji">{p.emoji || '🔗'}</div>
  <div class="c-en">{p.name_en || p.name_ko || ''}</div>
  {p.name_ko && <div class="c-ko">{p.name_ko}</div>}
  <div class="c-desc">{p.desc || ''}</div>
  <div class="c-foot">
    <span class="c-tag">{p.tag || 'project'}</span>
    <span class="c-go mono">↗</span>
  </div>
</a>

<style>
  .card {
    background: var(--card); border: 1px solid var(--line); border-radius: 13px;
    padding: 15px 16px; display: flex; flex-direction: column; gap: 7px;
    transition: transform .16s, box-shadow .16s, border-color .16s;
  }
  .card:hover { transform: translateY(-3px); box-shadow: 0 12px 30px var(--card-shadow); border-color: var(--muted); }
  .emoji { font-size: 21px; }
  .c-en { font-family: var(--mono); font-size: 13px; font-weight: 700; letter-spacing: -0.2px; }
  .c-ko { font-size: 12.5px; color: var(--ink-soft); }
  .c-desc { font-size: 12px; color: var(--muted); line-height: 1.5; flex: 1; }
  .c-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 2px; }
  .c-tag {
    font-family: var(--mono); font-size: 10.5px; letter-spacing: 1px; text-transform: uppercase;
    color: var(--muted); border: 1px solid var(--line); border-radius: 999px; padding: 3px 9px;
  }
  .c-go { font-family: var(--mono); font-size: 16px; }
</style>
