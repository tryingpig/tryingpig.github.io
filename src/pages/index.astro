---
import '../styles/tokens.css';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
// 유일한 React 아일랜드. 검색·페이저만 클라이언트에서 살아 움직인다.
import PostList from '../components/PostList.tsx';
import Footer from '../components/Footer.astro';
import { loadPosts } from '../lib/posts';

// ★ 빌드 타임에 딱 한 번 실행된다. 브라우저는 이 코드를 절대 받지 않는다.
// 프로젝트 목록은 본문에서 빠지고 Nav 의 드롭다운으로 들어갔다.
const posts = loadPosts();

// og:image·canonical 은 상대경로가 통하지 않아 절대 URL 이 필요하다 (끝의 / 유지)
const SITE = 'https://tryingpig.github.io/';
const desc = '노력하는뚱땡이의 학습공간 — 투자·개발 학습 기록과 직접 만든 프로젝트 모음.';
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>노력하는뚱땡이의 학습공간</title>
  <meta name="description" content={desc} />
  <link rel="canonical" href={SITE} />

  <!-- 파비콘: SVG 우선(픽셀 그대로 선명), iOS 홈화면은 PNG 만 받는다 -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- 텔레그램·카카오톡·슬랙 링크 미리보기. og:image 는 절대경로여야 하고,
       크롤러가 head 만 읽고 끊는 경우가 있어 상단에 둔다. -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="노력하는뚱땡이의 학습공간" />
  <meta property="og:title" content="노력하는뚱땡이의 학습공간" />
  <meta property="og:description" content={desc} />
  <meta property="og:url" content={SITE} />
  <meta property="og:image" content={SITE + 'og.png'} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="ko_KR" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="노력하는뚱땡이의 학습공간" />
  <meta name="twitter:description" content={desc} />
  <meta name="twitter:image" content={SITE + 'og.png'} />
  <script is:inline>
    /* 초기 테마 즉시 적용 (화면 깜빡임 방지). 저장값 없으면 시스템 설정 따름.
       is:inline — 번들로 빼면 실행이 늦어져 깜빡임이 생기므로 반드시 인라인 유지 */
    (function () {
      try {
        var t = localStorage.getItem('theme');
        if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      } catch (e) {}
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
</head>
<body>
  <Nav />

  <main id="top">
    <Hero />

    <section id="study" class="sec wrap reveal">
      {/* 섹션 헤더는 PostList 안으로 옮겼다 — 검색하면 개수가 '3 / 64' 로 바뀌어야 하므로 */}
      {posts.length === 0
        ? <div class="sec-head"><h2>Study &amp; Writings</h2></div>
        : <PostList posts={posts} perPage={10} client:load />}
      {posts.length === 0 && <div class="empty">아직 글이 없습니다.</div>}
    </section>
  </main>

  <Footer />

  <script>
    /* 아일랜드 #3 — 스크롤 리빌 */
    const io = new IntersectionObserver((entries) => {
      entries.forEach((en) => {
        if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); }
      });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
  </script>
</body>
</html>

<style>
  /* 프로젝트 섹션이 빠져 STUDY 가 첫 섹션이 됐다 — 히어로와 너무 붙지 않게 위쪽만 조금 띄운다 */
  #study { padding-top: 12px; }
</style>
