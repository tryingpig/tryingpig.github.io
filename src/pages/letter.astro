---
/* Newsletter / Content First 랜딩 — 메인(index.astro)과 독립된 별도 페이지.
   2026-07-24 공개. 상단 Nav 의 Letter 항목에서 들어온다.
   구독 폼의 수집처는 아직 없다 — 아래 <script> 참고. */
import '../styles/tokens.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import Footer from '../components/Footer.astro';
import { loadPosts, loadProjects } from '../lib/posts';

const posts = loadPosts();
const projects = loadProjects();

// 히어로 아래 미리보기로 쓸 최근 글
const recent = posts.slice(0, 6);

/* 통계는 전부 실제 데이터에서 뽑는다.
   시안에 있던 "구독자 1,240명" 같은 숫자는 근거가 없어 넣지 않았다 —
   지어낸 소셜 프루프는 이 사이트 성격과 맞지 않는다. */
const total = posts.length;
const oldest = posts.length ? posts[posts.length - 1].date.slice(0, 7).replace('-', '.') : '—';
const latest = posts.length ? posts[0].date.slice(0, 10).replace(/-/g, '.') : '—';

const SITE = 'https://tryingpig.github.io/';
const desc = '투자·개발을 공부하며 남긴 기록을 한곳에서. 노력하는뚱땡이의 학습 레터.';
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>학습 레터 — 노력하는뚱땡이의 학습공간</title>
  <meta name="description" content={desc} />

  <link rel="canonical" href={SITE + 'letter'} />

  <script is:inline>
    /* 초기 테마 즉시 적용 (index.astro 와 동일 — 깜빡임 방지용이라 인라인 유지) */
    (function () {
      try {
        var t = localStorage.getItem('theme');
        if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      } catch (e) {}
    })();
  </script>

  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="학습 레터 — 노력하는뚱땡이의 학습공간" />
  <meta property="og:description" content={desc} />
  <meta property="og:url" content={SITE + 'letter'} />
  <meta property="og:image" content={SITE + 'og.png'} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="ko_KR" />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
</head>
<body>

<!-- ── 1. 스티키 헤더 + 상시 구독 폼 ── -->
<header class="l-nav">
  <div class="wrap l-nav-inner">
    <a href="/" class="brand">tryingpig<span class="dot">.log</span></a>
    <div class="l-nav-right">
      <form class="mini-form" data-subscribe>
        <label class="sr-only" for="email-top">이메일 주소</label>
        <input id="email-top" type="email" name="email" placeholder="you@email.com" autocomplete="email" required />
        <button type="submit">구독</button>
      </form>
      <ThemeToggle />
    </div>
  </div>
</header>

<main>
  <!-- ── 2. 히어로 + 인라인 폼 ── -->
  <section class="l-hero wrap">
    <div class="eyebrow">study log &amp; projects</div>
    <h1>study,<br />build, <span class="accent">repeat.</span></h1>
    <p class="lead">투자·개발을 공부하며 남긴 기록을 모아 보냅니다. 광고 없이, 공부한 것만.</p>

    <form class="big-form" data-subscribe>
      <label class="sr-only" for="email-hero">이메일 주소</label>
      <input id="email-hero" type="email" name="email" placeholder="you@email.com" autocomplete="email" required />
      <button type="submit">무료로 구독하기</button>
    </form>
    <p class="form-msg" data-msg role="status" aria-live="polite"></p>

    <a class="sample" href="#recent">먼저 지난 글부터 읽어보기 ↓</a>
  </section>

  <!-- ── 3. 최근 글 / 아카이브 ── -->
  <section id="recent" class="sec wrap">
    <div class="sec-head">
      <h2>Recent Issues</h2>
      <span class="count">{String(total).padStart(2, '0')}</span>
    </div>

    {recent.length === 0
      ? <div class="empty">아직 글이 없습니다.</div>
      : <ul class="l-posts">
          {recent.map((p) => (
            <li>
              <a href={'/' + p.file}>
                <img src={p.icon} alt="" width={54} height={54} loading="lazy" />
                <span class="b">
                  <span class="t">{p.title}</span>
                  <span class="d">{p.date}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>}

    <a class="all-link" href="/#study">전체 {total}편 보기 →</a>
  </section>

  <!-- ── 4. 숫자 (실제 데이터만) ── -->
  <section class="sec wrap">
    <div class="stats">
      <div class="stat"><div class="n">{total}</div><div class="l">편의 기록</div></div>
      <div class="stat"><div class="n">{projects.length}</div><div class="l">개의 프로젝트</div></div>
      <div class="stat"><div class="n">{oldest}</div><div class="l">부터 기록 중</div></div>
      <div class="stat"><div class="n">{latest}</div><div class="l">마지막 갱신</div></div>
    </div>
  </section>

  <!-- ── 5. 글쓴이 ── -->
  <section class="sec wrap">
    <div class="sec-head"><h2>About</h2></div>
    <div class="about">
      <img src="/favicon.svg" alt="" width={62} height={62} class="ava" />
      <div>
        <h3>노력하는뚱땡이</h3>
        <p>투자와 개발을 공부하며 필요한 도구는 직접 만들어 씁니다. 여기 쌓인 글은 공부 기록이고,
           프로젝트는 그 과정에서 아쉬워서 만든 것들입니다. 남에게 권하는 글이 아니라, 제가 다시 보려고 정리한 글입니다.</p>
        <div class="proj-line">
          {projects.map((p, i) => (
            <>
              {i > 0 && <span class="sep">·</span>}
              <a href={p.url} target="_blank" rel="noopener">{p.name_ko || p.name_en}</a>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>
</main>

<Footer />

<script>
  /* 구독 폼 — 아직 받는 곳이 없다.
     제출을 가로채 안내만 띄운다. 메일 수집 서비스를 붙일 때 이 자리에 fetch 를 넣으면 된다.
     (실제로 저장되지 않는데 "구독 완료"라고 말하지 않는다) */
  document.querySelectorAll('[data-subscribe]').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const msg = document.querySelector('[data-msg]');
      if (msg) {
        msg.textContent = '구독 기능은 아직 준비 중입니다. 지금은 아래 글 목록을 이용해 주세요.';
        msg.classList.add('show');
      }
      document.getElementById('recent')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>

<style>
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
  }

  /* ── 헤더 ── */
  .l-nav {
    position: sticky; top: 0; z-index: 50;
    background: var(--nav-bg); backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line-soft);
  }
  .l-nav-inner { display: flex; align-items: center; justify-content: space-between; gap: 14px; height: 60px; }
  .brand { font-family: var(--mono); font-weight: 700; font-size: 15px; letter-spacing: -0.3px; flex: none; }
  .brand .dot { color: var(--muted); }
  .l-nav-right { display: flex; align-items: center; gap: 12px; }

  .mini-form { display: flex; gap: 6px; }
  .mini-form input {
    font-family: var(--mono); font-size: 11.5px; width: 168px;
    background: var(--card); color: var(--ink);
    border: 1px solid var(--line); border-radius: 8px; padding: 8px 10px;
  }
  .mini-form input::placeholder { color: var(--muted); }
  .mini-form button {
    font-family: var(--mono); font-size: 11.5px; font-weight: 700; white-space: nowrap;
    background: var(--accent); color: var(--bg);
    border: 1px solid var(--accent); border-radius: 8px; padding: 8px 13px; cursor: pointer;
  }
  /* 좁은 화면에서는 헤더 폼을 숨긴다 — 히어로의 큰 폼이 바로 아래에 있어 중복이다 */
  @media (max-width: 720px) { .mini-form { display: none; } }

  /* ── 히어로 ── */
  .l-hero { padding-top: 72px; padding-bottom: 48px; text-align: center; }
  .eyebrow {
    font-family: var(--mono); font-size: 12px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--muted); margin-bottom: 18px;
  }
  .l-hero h1 {
    font-family: var(--mono); font-weight: 700; line-height: 1.14;
    font-size: clamp(32px, 6.4vw, 54px); letter-spacing: -1px; margin: 0 0 16px;
  }
  .l-hero h1 .accent { color: var(--muted); }
  .l-hero .lead { font-size: 16px; color: var(--ink-soft); margin: 0 auto 28px; max-width: 460px; }

  .big-form { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
  .big-form input {
    font-family: var(--mono); font-size: 13.5px; width: min(280px, 100%);
    background: var(--card); color: var(--ink);
    border: 1px solid var(--line); border-radius: 10px; padding: 13px 15px;
  }
  .big-form input::placeholder { color: var(--muted); }
  .big-form button {
    font-family: var(--mono); font-size: 13px; font-weight: 700;
    background: var(--accent); color: var(--bg);
    border: 1px solid var(--accent); border-radius: 10px; padding: 13px 22px; cursor: pointer;
    transition: opacity .15s;
  }
  .big-form button:hover { opacity: .85; }

  .form-msg {
    font-family: var(--mono); font-size: 12px; color: var(--muted);
    margin: 14px 0 0; min-height: 18px; opacity: 0; transition: opacity .2s;
  }
  .form-msg.show { opacity: 1; }
  .sample {
    display: inline-block; margin-top: 10px;
    font-family: var(--mono); font-size: 12px; color: var(--ink-soft);
    text-decoration: underline; text-underline-offset: 3px;
  }
  .sample:hover { color: var(--ink); }

  /* ── 최근 글 ── */
  .l-posts { list-style: none; padding: 0; margin: 0; }
  .l-posts li { border-bottom: 1px solid var(--line-soft); }
  .l-posts a {
    display: flex; align-items: center; gap: 13px; padding: 11px 6px;
    transition: background .12s, padding-left .12s;
  }
  .l-posts a:hover { background: var(--bg-2); padding-left: 12px; }
  .l-posts a:hover .t { text-decoration: underline; }
  .l-posts img {
    flex: none; width: 54px; height: 54px; border-radius: 10px;
    border: 1px solid var(--line); background: var(--bg-2);
    image-rendering: pixelated; display: block;
  }
  .l-posts .b { min-width: 0; display: flex; flex-direction: column; gap: 5px; }
  .l-posts .t {
    font-size: 15px; color: var(--ink); line-height: 1.4;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .l-posts .d { font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .all-link {
    display: inline-block; margin-top: 18px;
    font-family: var(--mono); font-size: 12px; color: var(--ink-soft);
    text-decoration: underline; text-underline-offset: 3px;
  }
  .all-link:hover { color: var(--ink); }

  /* ── 숫자 ── */
  .stats { display: flex; gap: 12px; flex-wrap: wrap; }
  .stat {
    flex: 1; min-width: 132px;
    background: var(--card); border: 1px solid var(--line);
    border-radius: 12px; padding: 16px 18px;
  }
  .stat .n { font-family: var(--mono); font-size: 25px; font-weight: 700; line-height: 1.1; }
  .stat .l {
    font-family: var(--mono); font-size: 10.5px; letter-spacing: 1.2px;
    color: var(--muted); margin-top: 6px;
  }

  /* ── 글쓴이 ── */
  .about { display: flex; gap: 16px; align-items: flex-start; }
  .about .ava {
    flex: none; border-radius: 12px; border: 1px solid var(--line);
    image-rendering: pixelated; display: block;
  }
  .about h3 { margin: 0 0 7px; font-size: 15px; }
  .about p { margin: 0; font-size: 14px; color: var(--ink-soft); }
  .proj-line { margin-top: 12px; font-family: var(--mono); font-size: 12px; color: var(--muted); }
  .proj-line a { color: var(--ink-soft); text-decoration: underline; text-underline-offset: 3px; }
  .proj-line a:hover { color: var(--ink); }
  .proj-line .sep { margin: 0 7px; }

  /* 터치 기기 탭 영역 (메인과 같은 기준) */
  @media (pointer: coarse) {
    .mini-form input, .mini-form button { min-height: 44px; }
    .big-form input, .big-form button { min-height: 48px; }
  }
</style>

<!-- 남은 작업
     구독 폼에 실제 수집처 연결 (위 <script> 의 submit 핸들러).
     붙이기 전까지는 "준비 중" 안내만 뜬다 — 저장되지 않는데 완료라고 말하지 않기 위함.
-->
